---
const year = new Date().getFullYear();
---
<footer>
    <div>
        <div>
            <ul class="icons">
                <li><a href="https://github.com/dariomory" target="_blank" class="foot-btn"><span class="git-icon">GitHub</span></a></li>
                <li><a href="mailto:dario@mory.dev" class="foot-btn"><span class="mail-icon">Email</span></a></li>
                <li><a href="https://stackoverflow.com/users/5250453/dario-mory" target="_blank" class="foot-btn"><span class="so-icon">Stackoverflow</span></a></li>
                <li><a href="https://medium.com/@dariomory" target="_blank" class="foot-btn"><span class="medium-icon">Medium</span></a></li>
                <li><a href="https://www.reddit.com/user/dariomory/" target="_blank" class="foot-btn"><span class="reddit-icon">Reddit</span></a></li>
                <li><a href="/rss.xml" target="_blank" class="foot-btn"><span class="rss-icon">RSS</span></a></li>
            </ul>
        </div>
        <small>&copy; {year} mory.dev — All Rights Reserved.</small>
    </div>
</footer>
<style>
    footer {
        margin: 4rem 0;
    }

    ul.icons {
        cursor: default;
        list-style: none;
        padding: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: center;
        gap: 0.5rem;
    }

    ul.icons li {
        display: inline-block;
        padding: 0;
    }

    div {
        text-align: center;
    }

    small {
        font-family: 'Josefin Sans', sans-serif; 
    }

    small a {
        color: #375a7f;
        text-decoration: none;
    }

    @media only screen and (max-width: 600px) {
        ul.icons {
            gap: 0.5rem 0.45rem;
            /* space before the copyright line */
            margin-bottom: 1.5rem;
        }

        footer {
            /* a bit less space above the icon row than desktop (4rem) */
            margin-top: 2.5rem;
            /* room above home indicator on notched phones */
            padding-bottom: max(0.5rem, env(safe-area-inset-bottom, 0px));
        }
    }
</style>
